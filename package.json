    "db:studio": "bunx drizzle-kit studio",
    "db:up": "docker compose up -d",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@ton/core": "^0.61.0",
    "drizzle-orm": "^0.45.2",
    "pino": "^9.5.0",
    "postgres": "^3.4.9",
    "ton-lite-client": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  }
}
